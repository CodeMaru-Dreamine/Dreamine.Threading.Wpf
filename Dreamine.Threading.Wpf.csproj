<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFramework>net8.0-windows</TargetFramework>
		<Nullable>enable</Nullable>
		<UseWPF>true</UseWPF>
		<ImplicitUsings>enable</ImplicitUsings>

		<PackageId>Dreamine.Threading.Wpf</PackageId>
		<Version>1.0.0</Version>
		<Authors>Dreamine Core Team</Authors>
		<Company>Dreamine</Company>
		<Description>WPF monitoring UI components for Dreamine threading infrastructure.</Description>
		<PackageTags>dreamine;threading;wpf;mvvm;monitoring;worker;dotnet;csharp</PackageTags>
		<PackageLicenseExpression>MIT</PackageLicenseExpression>
		<RepositoryUrl>https://github.com/CodeMaru-Dreamine/Dreamine.Threading.Wpf</RepositoryUrl>
		<PackageProjectUrl>https://dreamine.kr/</PackageProjectUrl>
		<Title>Dreamine.Threading.Wpf</Title>
		<PackageReadmeFile>README.md</PackageReadmeFile>
		<PackageIcon>icon.png</PackageIcon>
		<GeneratePackageOnBuild>true</GeneratePackageOnBuild>
		<Copyright>© 2026 Dreamine Core Team. All rights reserved.</Copyright>
	</PropertyGroup>

	<ItemGroup>
		<ProjectReference Include="..\Core\Dreamine.MVVM.Core.csproj" />
		<ProjectReference Include="..\Threading.Windows\Dreamine.Threading.Windows.csproj" />
		<ProjectReference Include="..\Threading\Dreamine.Threading.csproj" />
	</ItemGroup>

	<ItemGroup>
		<None Update="README.md" Pack="true" PackagePath="\" />
		<None Update="README_KO.md" Pack="true" PackagePath="\" />
		<None Update="icon.png" Pack="true" PackagePath="\" />
	</ItemGroup>

</Project>